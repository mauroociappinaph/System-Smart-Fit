// Learn more about Prisma schema: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model HealthTelemetry {
  id               String @id
  userId           String
  metricType       String
  value            Float
  unit             String
  deviceTimestamp  BigInt
  serverReceivedAt BigInt
  correlationId    String

  @@map("health_telemetry")
}

model UserState {
  id             String   @id
  userId         String
  currentState   String
  previousState  String?
  transitionedAt BigInt
  correlationId  String
  deletedAt      BigInt?

  @@index([userId])
  @@index([currentState])
  @@index([userId, currentState])
  @@map("user_states")
}

model AgentInsight {
  id               String   @id
  userId           String
  correlationId    String
  category         String
  content          String
  score            Float
  validationStatus String
  createdAt        BigInt
  updatedAt        BigInt

  @@index([userId])
  @@index([validationStatus])
  @@index([userId, validationStatus])
  @@map("agent_insights")
}

model User {
  id           String @id
  name         String
  weightKg     Float
  heightCm     Float
  birthDate    BigInt
  goal         String
  registeredAt BigInt

  @@map("users")
}

